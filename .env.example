# MongoDB
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?appName=portfolio
MONGO_DB_NAME=portfolio

# Flask + JWT (use a long random string in production)
SECRET_KEY=change-me-to-a-long-random-string

# Admin login (change password!)
ADMIN_USER=admin@example.com
ADMIN_PASS=changeme

# Optional: contact form email (see BACKEND/utils/mail.py)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# CONTACT_TO_EMAIL=

# Optional: Cloudinary image uploads (admin panel)
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLOUD_NAME=

# Optional: email notifications for contact form (leave empty to skip sending)
