# ============================================================
# Backend Configuration (.env)
# ============================================================
# This file contains sensitive credentials - NEVER commit to Git!
# Use a strong SECRET_KEY in production (change "dev-key" to something secure)
# 
# Copy this to .env and fill in your actual values
# ============================================================

# ==================== MONGODB ==================== 
# Get your MongoDB URI from MongoDB Atlas:
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create a free cluster
# 3. Click "Connect" and copy your connection string
# 4. Include USERNAME and PASSWORD in the URI

MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?appName=portfolio
MONGO_DB_NAME=portfolio

# ==================== FLASK SECURITY ====================
# Security: Use a long random string in production!
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
# Never use: dev-key, secret123, or any simple string in production

SECRET_KEY=change-me-to-a-long-random-string

# ==================== ADMIN CREDENTIALS ====================
# Change these to your actual admin login
# Used for admin panel authentication

ADMIN_USER=admin@example.com
ADMIN_PASS=changeme

# ==================== CORS CONFIGURATION ====================
# Comma-separated list of allowed frontend URLs
# Only these origins can make requests to your API

ALLOWED_ORIGINS=https://mr-ankish.vercel.app,http://localhost:5173,http://localhost:3000

# ==================== EMAIL (OPTIONAL) ====================
# If you want to send emails from contact form
# Using Gmail? Generate app-specific password at:
# https://myaccount.google.com/apppasswords

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# CONTACT_TO_EMAIL=admin@example.com

# ==================== CLOUDINARY (OPTIONAL) ====================
# For image uploads in admin panel
# Get credentials from https://cloudinary.com (free tier available)

# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ==================== ENVIRONMENT ====================
# Indicates development vs production environment

FLASK_ENV=production
