{
  "name": "mr-ankish-client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c yellow,cyan \"npm run dev:api\" \"npm run dev:web\"",
    "dev:vite": "vite",
    "dev:api": "node ../BACKEND/scripts/start-backend.mjs",
    "dev:web": "wait-on -t 120000 http://127.0.0.1:5000/api/health && vite",
    "dev:full": "npm run dev",
    "start": "npm run dev",
    "setup:backend": "node ../BACKEND/scripts/ensure-backend-deps.mjs",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^9.0.3",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.2",
    "vite": "^6.0.3",
    "wait-on": "^9.0.4"
  }
}
